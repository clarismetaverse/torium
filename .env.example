# Apify
# Get this from Apify Console -> Settings -> Integrations -> API token
# Never put the real token in this file.
# Put the real token only in your local .env file.
APIFY_TOKEN=

# TORIUM scraper defaults
# Idealista supports location as a city name or an Idealista Location ID.
TORIUM_CITY=Milano

# Optional later
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
