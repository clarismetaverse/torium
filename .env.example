# Apify
# Get this from Apify Console -> Settings -> Integrations -> API token
# Never put the real token in this file.
# Put the real token only in your local .env file.
APIFY_TOKEN=

# TORIUM scraper defaults
# Idealista supports location as a city name or an Idealista Location ID.
TORIUM_CITY=Milano

# OpenAI API
# Put the real key only in your local .env file.
OPENAI_API_KEY=

# Model default. Change locally if needed.
OPENAI_MODEL=gpt-5.2

# Optional Gemini later
GEMINI_API_KEY=

# Triage limits
TORIUM_TRIAGE_MAX_ITEMS=20
TORIUM_GPT_TRIAGE_LIMIT=5

# Optional Xano sync
# When set, every triage run is POSTed to this endpoint after the local JSON is saved.
XANO_TRIAGE_POST_URL=

# Optional. Use only if your Xano endpoint requires Bearer auth.
XANO_TRIAGE_API_KEY=
