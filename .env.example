# Apify
# Get this from Apify Console -> Settings -> Integrations -> API token
# Never put the real token in this file.
# Put the real token only in your local .env file.
APIFY_TOKEN=

# TORIUM scraper defaults
TORIUM_CITY=Milano
TORIUM_MIN_SIZE=80
TORIUM_MIN_ROOMS=1
TORIUM_MAX_ROOMS=12
TORIUM_BATHROOMS=1

# OpenAI API
# Put the real key only in your local .env file.
OPENAI_API_KEY=

# Model default. Change locally if needed.
OPENAI_MODEL=gpt-5.2

# Optional Gemini later
GEMINI_API_KEY=

# Triage limits
TORIUM_TRIAGE_MAX_ITEMS=20
TORIUM_GPT_TRIAGE_LIMIT=5

# Massive multisource triage
# scout is the safe default: 1 page, ~20 results, one/two areas.
# normal/deep should be used only after checking the generated URLs with TORIUM_DRY_RUN=true.
TORIUM_RUN_MODE=scout
TORIUM_MASSIVE_SOURCES=immobiliare
TORIUM_IMMOBILIARE_ACTOR=url
TORIUM_MASSIVE_AREAS=corso-san-gottardo
TORIUM_MASSIVE_MAX_ITEMS_PER_QUERY=20
TORIUM_MASSIVE_MAX_PAGES_PER_QUERY=1
TORIUM_MASSIVE_MAX_TOTAL_RAW_LISTINGS=40
TORIUM_MASSIVE_TOP_PRESCORE_LIMIT=40
TORIUM_MASSIVE_INCLUDE_RENOVATION_VARIANT=true
TORIUM_MASSIVE_INCLUDE_DISCOUNTED_VARIANT=false

# Immobiliare URL params
# condition code 5 corresponds to "Da ristrutturare" from the generated URL.
TORIUM_IMMOBILIARE_CONDITION_CODE=5
TORIUM_IMMOBILIARE_HEATING_CODE=1
TORIUM_IMMOBILIARE_GARAGE_CODE=1
TORIUM_IMMOBILIARE_OWNERSHIP_CODE=1
TORIUM_IMMOBILIARE_FURNISHED=true
TORIUM_IMMOBILIARE_EXCLUDE_AUCTIONS=false

# Local JSON output is off by default.
# Set to true only when you want backup files in outputs/triage.
TORIUM_SAVE_LOCAL_JSON=false

# Supabase sync
# Project URL is safe to store here as a placeholder; put real values only in local .env / Vercel env vars.
SUPABASE_URL=

# Never expose this in frontend code. Use only in local pipeline or Vercel serverless API env vars.
SUPABASE_SERVICE_ROLE_KEY=
